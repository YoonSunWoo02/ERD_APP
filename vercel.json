{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "server/api-server.js",
      "use": "@vercel/node"
    },
    {
      "src": "widget/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "installCommand": "cd widget && npm install",
        "buildCommand": "cd widget && npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/api-server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "widget/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "widget/dist/index.html"
    }
  ]
}
