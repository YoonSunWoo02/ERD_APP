{
  "version": 2,
  "builds": [
    {
      "src": "server/api-server.js",
      "use": "@vercel/node"
    },
    {
      "src": "widget/package.json",
      "use": "@vercel/vite"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/api-server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
