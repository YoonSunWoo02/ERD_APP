{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "server/api-server.js",
      "use": "@vercel/node"
    },
    {
      "src": "widget/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "installCommand": "cd widget && npm install",
        "buildCommand": "cd widget && npm run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server/api-server.js"
    },
    {
      "source": "/((?!api/|assets/|.*\\.(js|css|ico|png|svg|woff2?)$).*)",
      "destination": "/index.html"
    }
  ]
}
